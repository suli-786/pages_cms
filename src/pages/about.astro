---
// About page — Ummah Tech.
// All copy comes from src/content/about.json (edited via Pages CMS); each
// section renders from its `content` prop and can be toggled on/off with the
// section's "Show section" switch in the CMS (`visible`).
//
// Pro blocks adapted into the template's design:
//   story.tsx    ← @shadcnblocks/about6
//   why.tsx      ← @shadcnblocks/feature76
//   beliefs.tsx  ← @shadcnblocks/feature362
//   values.tsx   ← @shadcnblocks/feature26
// intro / faith / team are bespoke (no registry block fits a brand statement,
// a scripture pull-quote, or an honest "team coming soon"); the closing join
// section reuses the homepage's cta.tsx.
//
// The closing join section (cta.tsx, countdown state) is the page's only
// client: island — every other section is static.
import Beliefs from '@/components/sections/about/beliefs';
import Faith from '@/components/sections/about/faith';
import Story from '@/components/sections/about/story';
import Team from '@/components/sections/about/team';
import Values from '@/components/sections/about/values';
import Why from '@/components/sections/about/why';
import Cta from '@/components/sections/cta';
import PageIntro from '@/components/sections/page-intro';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { about as rawAbout } from '@/lib/about';
import { resolveAboutImages } from '@/lib/images-about';

// Optimize every CMS image path (resize + WebP + srcset) at build time — see
// src/lib/images-about.ts.
const about = await resolveAboutImages(rawAbout);
---

<DefaultLayout
  title="About Ummah Tech — more than a conference, a movement"
  description="Ummah Tech is a movement of Muslim technologists, founders and creatives growing out of South Africa, building technology rooted in Islamic values."
>
  <!-- Intro → bracketed mission statement. Carries the page's h1. -->
  {about.intro.visible && <PageIntro content={about.intro} />}

  <!-- Our story → 2024 to today, with a staggered photo grid -->
  {about.story.visible && <Story content={about.story} />}

  <!-- Why we exist → the challenges, as a bordered column band -->
  {about.why.visible && <Why content={about.why} />}

  <!-- Rooted in faith → Qur'an 5:2 in a corner-bracket frame -->
  {about.faith.visible && <Faith content={about.faith} />}

  <!-- What we stand for → six numbered propositions, sticky heading -->
  {about.beliefs.visible && <Beliefs content={about.beliefs} />}

  <!-- Our values → six icon-led values -->
  {about.values.visible && <Values content={about.values} />}

  <!-- Who's behind Ummah Tech → interim copy until real bios land -->
  {about.team.visible && <Team content={about.team} />}

  <!-- Join → the closing conversion, shared with the homepage's final CTA -->
  {about.join.visible && <Cta content={about.join} client:visible />}
</DefaultLayout>
