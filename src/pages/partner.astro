---
// Partner page — Ummah Tech. Solely for sponsors and partner organisations.
// All copy comes from src/content/partner.json (edited via Pages CMS); each
// section renders from its `content` prop and can be toggled with its "Show
// section" switch (`visible`).
//
// Pro blocks adapted into the template's design:
//   why.tsx    ← @shadcnblocks/feature203
//   tiers.tsx  ← @shadcnblocks/pricing23 (comparison matrix, no prices)
// The other sections are shared with the rest of the site: the intro band
// (promoted from the About page), the partners section (the homepage's framed
// spotlights + marquee, here holding CURRENT partners) and the closing
// contact section (the homepage's form, preselected on the Partner enquiry
// type). Two client: islands — the tiers matrix (its mobile tier switcher;
// hydrated via client:media on small screens only) and the contact form.
import Contact from '@/components/sections/contact';
import PageIntro from '@/components/sections/page-intro';
import Tiers from '@/components/sections/partner/tiers';
import Why from '@/components/sections/partner/why';
import Partners from '@/components/sections/partners';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { resolvePartnerImages } from '@/lib/images-partner';
import { partner as rawPartner } from '@/lib/partner';

// Optimize every CMS image path (partner logos) at build time — see
// src/lib/images-partner.ts.
const partner = await resolvePartnerImages(rawPartner);
---

<DefaultLayout
  title="Partner With Us — Ummah Tech"
  description="Partner with Ummah Tech: put your organisation behind South Africa's community of Muslim technologists, founders and creatives — three partnership tiers around the annual conference and a year-round community."
>
  <!-- Intro → bracketed statement. Carries the page's h1. -->
  {partner.intro.visible && <PageIntro content={partner.intro} />}

  <!-- Why partner → the four pillars as icon cards -->
  {partner.why.visible && <Why content={partner.why} />}

  <!-- Current partners → the homepage partners design (framed spotlights +
       marquee). Hidden until the first partner is added in the CMS: an empty
       "current partners" section on a sponsor page is anti-social-proof. -->
  {
    partner.partners.visible && partner.partners.items.length > 0 && (
      <Partners content={partner.partners} />
    )
  }

  <!-- Partnership tiers → comparison matrix, no prices; prospectus by email.
       JS only serves the mobile tier switcher, so hydrate below md only. -->
  {
    partner.tiers.visible && (
      <Tiers content={partner.tiers} client:media="(max-width: 767px)" />
    )
  }

  <!-- Contact → the homepage's shared form section, narrowed to the two
       enquiry types that make sense for sponsors and preselected on Partner -->
  {
    partner.contact.visible && (
      <Contact
        content={partner.contact}
        defaultFunction="partner"
        functions={['contact', 'partner']}
        client:visible
      />
    )
  }
</DefaultLayout>
