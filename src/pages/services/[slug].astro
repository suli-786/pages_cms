---
import { getCollection, render } from 'astro:content';

import MoreServices from '@/components/sections/services-page/more-services';
import ServiceArticleHero from '@/components/sections/services-page/article-hero';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getAllServices } from '@/lib/services';

export async function getStaticPaths() {
  const entries = await getCollection('services');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const service = entry.data;
const { Content } = await render(entry);

const all = await getAllServices();
const others = all.filter((s) => s.slug !== service.slug);
---

<DefaultLayout>
  <ServiceArticleHero frontmatter={service}>
    <div
      class="prose max-w-none prose-neutral md:prose-lg prose-p:my-6 prose-p:leading-relaxed prose-p:text-muted-foreground prose-strong:font-medium prose-strong:text-foreground prose-a:text-foreground prose-a:decoration-foreground/30 prose-a:underline-offset-4 hover:prose-a:decoration-foreground"
    >
      <Content />
    </div>
  </ServiceArticleHero>

  <MoreServices services={others} />
</DefaultLayout>
