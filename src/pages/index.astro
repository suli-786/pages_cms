---
// Homepage — Ummah Tech Conference.
// All copy & images come from src/content/home.json (edited via Pages CMS);
// each section renders from its `content` prop and can be toggled on/off with
// the section's "Show section" switch in the CMS (`visible`).
//
// Pro blocks adapted into the template's design:
//   hero.tsx              ← @shadcnblocks/hero272
//   about.tsx             ← @shadcnblocks/feature288
//   conference-intro.tsx  ← @shadcnblocks/feature71 (includes Why Attend)
//   partners.tsx          ← @shadcnblocks/logos20
import About from '@/components/sections/about';
import ConferenceIntro from '@/components/sections/conference-intro';
import Contact from '@/components/sections/contact';
import Cta from '@/components/sections/cta';
import Hero from '@/components/sections/hero';
import Partners from '@/components/sections/partners';
import Team from '@/components/sections/team';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { home } from '@/lib/home';
import { site } from '@/lib/site';
---

<DefaultLayout>
  <!-- Hero → statement, date/venue, ticket CTA, WhatsApp community invite,
       social links, rotating photo grid. Social links are cross-fed from Site
       settings so the CMS holds that list once. -->
  {
    home.hero.visible && (
      <Hero content={home.hero} socials={site.socials} client:load />
    )
  }

  <!-- Vision → large centered statement with hover photo previews -->
  {home.vision.visible && <About content={home.vision} client:visible />}

  <!-- Conference intro + Why Attend → header, photo tiles, benefit cells -->
  {home.conference.visible && <ConferenceIntro content={home.conference} />}

  <!-- Speakers → even card grid -->
  {home.speakers.visible && <Team content={home.speakers} client:visible />}

  <!-- Our Partners → counter-scrolling logo rows -->
  {home.partners.visible && <Partners content={home.partners} />}

  <!-- Final CTA -->
  {home.finalCta.visible && <Cta content={home.finalCta} />}

  <!-- Newsletter / lead-capture form -->
  {
    home.newsletter.visible && (
      <Contact content={home.newsletter} client:visible />
    )
  }
</DefaultLayout>
