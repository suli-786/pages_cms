---
import BaseHead from '@/components/BaseHead.astro';
import Banner from '@/components/layout/banner';
import Footer from '@/components/layout/footer';
import Navbar from '@/components/layout/navbar';
import { StyleGlideProvider } from '@/components/providers/styleglide-provider';
import { site } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="flex min-h-screen flex-col">
    <StyleGlideProvider client:only="react" />
    <Banner pathname={pathname} initialVisible={true} client:load />
    <Navbar
      pathname={pathname}
      initialBannerVisible={true}
      logo={site.logo}
      siteName={site.siteName}
      client:load
    />
    <main class="relative flex-1">
      <slot />
    </main>
    <Footer logo={site.logo} siteName={site.siteName} />
  </body>
</html>
