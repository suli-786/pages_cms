---
import BaseHead from '@/components/BaseHead.astro';
import Footer from '@/components/layout/footer';
import Navbar from '@/components/layout/navbar';
import { StyleGlideProvider } from '@/components/providers/styleglide-provider';
import { site } from '@/lib/site';
import { getPalette } from '@/lib/theme';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Set on pages whose first section is a dark full-bleed band — see navbar.tsx. */
  darkHero?: boolean;
}

const { title, description, image, darkHero = false } = Astro.props;
const pathname = Astro.url.pathname;

// The admin's Pages CMS palette choice reaches the DOM here and nowhere else.
// Build-time, so there is no runtime JS and no flash of the wrong colour. The
// default palette's class is '', which class:list drops.
const palette = getPalette(site.palette);
---

<!doctype html>
<html lang="en" class:list={[palette.htmlClass]}>
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="focus:bg-primary focus:text-primary-foreground focus:ring-ring sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:rounded-full focus:px-5 focus:py-3 focus:text-sm focus:font-medium focus:ring-2 focus:outline-none"
    >
      Skip to main content
    </a>
    {/* Dev-only theming overlay — never shipped to production visitors. */}
    {import.meta.env.DEV && <StyleGlideProvider client:only="react" />}
    <Navbar pathname={pathname} darkHero={darkHero} client:idle />
    <main id="main" tabindex="-1" class="relative flex-1 outline-none">
      <slot />
    </main>
    <Footer socials={site.socials} whatsapp={site.whatsapp} client:visible />
  </body>
</html>
